# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Placeholder for MongoDB, PostgreSQL, SQLite, etc.)
DB_TYPE=sqlite
DB_URI=sqlite://scamshield.db

# AI Integration Service Endpoint (Parth & Pushkar's AI Microservice)
AI_SERVICE_URL=http://localhost:8000/api/predict

# JWT Authentication Secret
JWT_SECRET=supersecretchangeinproduction123!
JWT_EXPIRE=30d

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Choose any secret string — enter the same value when registering the webhook in Meta
WHATSAPP_VERIFY_TOKEN=scamshield_verify_2024
